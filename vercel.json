{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "cd api && npm install",
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/(.*)",       "destination": "/index.html"   }
  ]
}
